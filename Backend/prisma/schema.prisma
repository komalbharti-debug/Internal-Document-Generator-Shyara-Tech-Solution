generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Template {
  id           Int        @id @default(autoincrement())
  name         String
  department   String
  content      String
  createdAt    DateTime   @default(now())
  filePath     String?
  placeholders String?
  documents    Document[]
}

model Document {
  id              Int      @id @default(autoincrement())
  templateId      Int
  content         String
  createdAt       DateTime @default(now())
  filePath        String?
  metadata        String?
  department      String?
  documentName    String?
  referenceNumber String?  @unique
  template        Template @relation(fields: [templateId], references: [id])

  @@index([createdAt])
  @@index([department])
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model ReferenceCounter {
  id           Int    @id @default(autoincrement())
  department   String
  documentType String
  currentValue Int    @default(0)

  @@unique([department, documentType])
}

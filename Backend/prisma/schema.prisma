generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Template {
  id         Int      @id @default(autoincrement())
  name       String
  department String
  content    String
  createdAt  DateTime @default(now())

  documents  Document[]
}

model Document {
  id         Int      @id @default(autoincrement())
  templateId Int
  content    String
  createdAt  DateTime @default(now())

  template   Template @relation(fields: [templateId], references: [id])
}